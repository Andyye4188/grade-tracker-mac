{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grade Tracker",
  "version": "1.0.0",
  "identifier": "com.gradetracker.mac",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Grade Tracker",
        "width": 900,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "url": "index.html",
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src": "src"
    }
  }
}